# Ambiente
# Em produção esta variável NUNCA pode valer "development" — isso habilita a rota
# GET /dev/promote-me, que promove qualquer usuário logado a administrador.
NODE_ENV=development

# Domínio
DOMAIN_LOCAL=
DOMAIN_PROD=

# Banco de dados
DIRECT_URL=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_TIME_SET_SECRET=

# E-mail (SMTP)
EMAIL_SMTP=
PASS_SMTP=

# SIRV CHAVE DE ACESSO
SIRV_Client_ID=
CLIENT_SECRET=

# Redis / Cache
API_KEY_REDIS=
REDIS_HOST=
REDIS_PORT=

#google
# O redirect_uri não é mais fixo por variável de ambiente: é calculado a partir do
# protocolo/host da própria requisição (protocol + Host header), para funcionar tanto em
# http://localhost:3000 quanto atrás de um túnel (ngrok/cloudflared). Por isso, TODOS os
# domínios usados para testar login (localhost:3000 e a URL pública do túnel, ambas com o
# path /auth/google/callback) precisam estar cadastrados em "Authorized redirect URIs" no
# Google Cloud Console — senão o Google recusa com redirect_uri_mismatch.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# Mercado Pago
# A API do Mercado Pago é sempre https://api.mercadopago.com — não existe host separado
# para teste; o modo sandbox é decidido pelo próprio access token usado, nunca pela URL.
# Com NODE_ENV=development a aplicação usa MP_ACCESS_TOKEN_TEST; qualquer outro valor
# (produção) usa MP_ACCESS_TOKEN. Gere o token de teste em "Suas integrações > Credenciais
# de teste" no painel do Mercado Pago.
# Desde nov/2025 o Mercado Pago também emite credenciais de teste no formato APP_USR-
# (igual às de produção), então o código não consegue diferenciar teste de produção pelo
# prefixo do token — a responsabilidade de colocar o valor certo em cada variável é sua.
# Se o app ainda não tem produção ativada, deixe MP_ACCESS_TOKEN_TEST com a credencial de
# teste e só preencha MP_ACCESS_TOKEN quando (e se) o negócio ativar produção de verdade.
# ATENÇÃO — Pix não tem sandbox no Mercado Pago (confirmado na documentação oficial:
# pagamentos Pix não podem ser feitos com credenciais de teste). Mesmo com
# MP_ACCESS_TOKEN_TEST configurado corretamente, o checkout PIX real só é testável de fato
# com MP_ACCESS_TOKEN (produção) e um valor simbólico (ex. R$ 1,00). MP_ACCESS_TOKEN_TEST
# ainda vale a pena manter — protege contra usar a credencial de produção por engano em
# qualquer chamada que não seja a criação do PIX em si — mas não espere um QR de teste.
MP_ACCESS_TOKEN_TEST=
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
# URL pública (ex.: túnel ngrok/cloudflared) cadastrada no painel do Mercado Pago para
# receber webhooks em desenvolvimento. Não é lida pela aplicação — uso manual/operacional.
MP_URL_TESTE=